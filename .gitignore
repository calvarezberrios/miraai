# Virtual environments
.venv/
# dedicated Python 3.10 venv for the Kokoro TTS subprocess
.venv-kokoro/
venv/
env/

# Python artifacts
__pycache__/
*.py[cod]
*.egg-info/
build/
dist/

# Secrets & config — API keys for OpenAI/Anthropic, Twitch, YouTube, ElevenLabs, etc.
.env
.env.*
*.key
secrets.json
config.local.json
token.json
credentials.json

# AI models & weights (huge files, don't commit)
models/
*.pt
*.pth
*.onnx
*.safetensors
*.gguf
*.ckpt
*.bin
.claude/

# Audio / TTS output
audio_output/
tts_cache/
recordings/
*.wav
*.mp3
*.ogg
*.flac

# Logs & chat history
logs/
*.log
chat_history/
memory/
memory_store/
*.db
*.sqlite3

# Note-taking sessions (DLPFC scribe) — contain conversation content (user data)
notes/

# Discord voice debug dumps (MIRA_VOICE_DUMP=1) — captured utterance WAVs, diagnostic only
voice_debug/

# VTuber assets (if large — Live2D/VRM models can be hefty)
# Uncomment if you don't want them in the repo:
# assets/models/
# *.vrm
# *.model3.json

# IDE / OS junk
.vscode/
.idea/
.DS_Store
Thumbs.db

# Jupyter (if you experiment in notebooks)
.ipynb_checkpoints/
test_out.wav
test_piper.wav
test_rvc.wav

# Piper voice models (large ONNX files)
piper_voices/

# Avatar renderer deps — vendored via `npm install` in avatar/ (package.json kept).
# node_modules is large and reproducible; the .vrm model is a heavy binary asset.
avatar/node_modules/
avatar/mira.vrm
# VRMA gesture clips — local-only assets (verify rights before redistributing)
avatar/animations/

# RVC model files / archives (placed by user, not in repo) — ignore the whole dir
rvc_models/
*.zip
